<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:CelestialMapper.UI">

    <!--  Dynamic Editor Selector using Converter  -->
    <local:PropertyValueEditorSelector x:Key="Selector.PropertyValueEditor" />

    <!--  Property List DataGrid Styles  -->

    <!--  Alternating Row Style  -->
    <Style x:Key="Style.DataGridRow.PropertyList" TargetType="{x:Type DataGridRow}">
        <Style.Triggers>
            <Trigger Property="ItemsControl.AlternationIndex" Value="0">
                <Setter Property="Background" Value="White" />
            </Trigger>
            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                <Setter Property="Background" Value="#F5F5F5" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#E3F2FD" />
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsSelected" Value="True" />
                    <Condition Property="IsMouseOver" Value="True" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="#BBDEFB" />
            </MultiTrigger>
        </Style.Triggers>
    </Style>

    <!--  Column Header Style  -->
    <Style x:Key="Style.DataGridColumnHeader.PropertyList" TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="Background" Value="#E0E0E0" />
        <Setter Property="Foreground" Value="Black" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="BorderBrush" Value="#CCCCCC" />
    </Style>

    <!--  Cell Style  -->
    <Style x:Key="Style.DataGridCell.PropertyList" TargetType="{x:Type DataGridCell}">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="Black" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  String Editor Template  -->
    <DataTemplate x:Key="Template.PropertyEditor.String">
        <TextBox
            VerticalAlignment="Center"
            BorderBrush="#CCCCCC"
            BorderThickness="1"
            Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
    </DataTemplate>

    <!--  Double Editor Template  -->
    <DataTemplate x:Key="Template.PropertyEditor.Double">
        <TextBox
            VerticalAlignment="Center"
            BorderBrush="#CCCCCC"
            BorderThickness="1"
            Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=G}" />
    </DataTemplate>

    <!--  Int Editor Template  -->
    <DataTemplate x:Key="Template.PropertyEditor.Int">
        <TextBox
            VerticalAlignment="Center"
            BorderBrush="#CCCCCC"
            BorderThickness="1"
            Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
    </DataTemplate>

    <!--  Bool Editor Template  -->
    <DataTemplate x:Key="Template.PropertyEditor.Bool">
        <CheckBox
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            IsChecked="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
    </DataTemplate>

    <!--  DateTime Editor Template  -->
    <DataTemplate x:Key="Template.PropertyEditor.DateTime">
        <DatePicker
            VerticalAlignment="Center"
            BorderBrush="#CCCCCC"
            BorderThickness="1"
            SelectedDate="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
    </DataTemplate>

    <!--  TimeSpan Editor Template  -->
    <DataTemplate x:Key="Template.PropertyEditor.TimeSpan">
        <local:TimePicker
            VerticalAlignment="Center"
            BorderBrush="#CCCCCC"
            BorderThickness="1"
            SelectedTime="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
    </DataTemplate>

    <!--  Enum Editor Template  -->
    <DataTemplate x:Key="Template.PropertyEditor.Enum">
        <ComboBox
            VerticalAlignment="Center"
            BorderBrush="#CCCCCC"
            BorderThickness="1"
            ItemsSource="{Binding Value, Mode=OneWay, Converter={x:Static local:Converters.EnumValues}}"
            SelectedItem="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
    </DataTemplate>

    <!--  Default Read-Only Template  -->
    <DataTemplate x:Key="Template.PropertyEditor.ReadOnly">
        <TextBlock
            VerticalAlignment="Center"
            Foreground="Gray"
            Text="{Binding Value, Mode=OneWay}" />
    </DataTemplate>

    <!--  Main DataGrid Style  -->
    <Style x:Key="Style.DataGrid.PropertyList" TargetType="{x:Type DataGrid}">
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="CanUserDeleteRows" Value="False" />
        <Setter Property="CanUserReorderColumns" Value="False" />
        <Setter Property="CanUserResizeRows" Value="False" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="RowHeaderWidth" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="AlternationCount" Value="2" />
        <Setter Property="RowStyle" Value="{StaticResource Style.DataGridRow.PropertyList}" />
        <Setter Property="ColumnHeaderStyle" Value="{StaticResource Style.DataGridColumnHeader.PropertyList}" />
        <Setter Property="CellStyle" Value="{StaticResource Style.DataGridCell.PropertyList}" />
    </Style>

</ResourceDictionary>