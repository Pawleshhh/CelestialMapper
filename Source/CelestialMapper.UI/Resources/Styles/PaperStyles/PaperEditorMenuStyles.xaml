<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:CelestialMapper.UI"
    xmlns:ui="clr-namespace:CelestialMapper.UI"
    xmlns:vm="clr-namespace:CelestialMapper.ViewModel;assembly=CelestialMapper.ViewModel">

    <DataTemplate x:Key="Private.DataTemplate.PaperEditorMenuStyles.TextItem.Settings" DataType="{x:Type vm:TextItem}">
        <TextBlock Text="TextItem settings" />
    </DataTemplate>

    <DataTemplate x:Key="Private.DataTemplate.PaperEditorMenuStyles.Map.Settings" DataType="{x:Type vm:MapViewModel}">
        <StackPanel Background="{DynamicResource Brush.ToolBackground}" Orientation="Vertical">
            <StackPanel.Resources>
                <Style TargetType="{x:Type local:LabeledTextBox}">
                    <Setter Property="Margin" Value="4" />
                </Style>
                <Style TargetType="{x:Type TextBox}">
                    <Setter Property="Margin" Value="4" />
                </Style>
            </StackPanel.Resources>

            <local:LabeledTextBox Label="Latitude:">
                <local:LabeledTextBox.Text>
                    <Binding
                        Mode="TwoWay"
                        Path="LatitudeInput"
                        UpdateSourceTrigger="PropertyChanged">
                        <Binding.ValidationRules>
                            <local:DoubleInputValidation
                                InvalidResultString="String.Latitude.Error"
                                MaxValue="90"
                                MinValue="-90" />
                        </Binding.ValidationRules>
                    </Binding>
                </local:LabeledTextBox.Text>
            </local:LabeledTextBox>

            <local:LabeledTextBox Label="Longitude:">
                <local:LabeledTextBox.Text>
                    <Binding
                        Mode="TwoWay"
                        Path="LongitudeInput"
                        UpdateSourceTrigger="PropertyChanged">
                        <Binding.ValidationRules>
                            <local:DoubleInputValidation
                                InvalidResultString="String.Longitude.Error"
                                MaxValue="180"
                                MinValue="-180" />
                        </Binding.ValidationRules>
                    </Binding>
                </local:LabeledTextBox.Text>
            </local:LabeledTextBox>

            <HeaderedContentControl Header="Date:" Style="{StaticResource Style.HeaderedContentControl}">
                <DatePicker SelectedDate="{Binding DateTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </HeaderedContentControl>

            <HeaderedContentControl Header="Time:" Style="{StaticResource Style.HeaderedContentControl}">
                <local:TimePicker SelectedTime="{Binding Time, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </HeaderedContentControl>

            <Button Command="{Binding ApplyCommand}" Content="Apply" />

        </StackPanel>
    </DataTemplate>

    <ui:DataTypeTemplateSelector x:Key="Private.DataTemplateSelector.PaperEditorMenu.SpecificSettings">
        <ui:PlatformDataTemplateSelectorItem DataTemplate="{StaticResource Private.DataTemplate.PaperEditorMenuStyles.TextItem.Settings}" />
        <ui:PlatformDataTemplateSelectorItem DataTemplate="{StaticResource Private.DataTemplate.PaperEditorMenuStyles.Map.Settings}" />
    </ui:DataTypeTemplateSelector>

    <Style x:Key="Style.ContentControl.PaperEditorMenu.SpecificSettings" TargetType="{x:Type ContentControl}">
        <Setter Property="ContentTemplateSelector" Value="{StaticResource Private.DataTemplateSelector.PaperEditorMenu.SpecificSettings}" />
    </Style>

</ResourceDictionary>