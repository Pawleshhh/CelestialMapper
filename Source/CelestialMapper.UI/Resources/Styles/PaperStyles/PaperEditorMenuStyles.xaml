<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:CelestialMapper.UI"
    xmlns:ui="clr-namespace:CelestialMapper.UI"
    xmlns:vm="clr-namespace:CelestialMapper.ViewModel;assembly=CelestialMapper.ViewModel">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="../Other/PropertyListStyles.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <DataTemplate x:Key="Private.DataTemplate.PaperEditorMenuStyles.TextItem.Settings" DataType="{x:Type vm:TextItem}">
        
        <!--<StackPanel Background="{DynamicResource Brush.ToolBackground}" Orientation="Vertical">

            <HeaderedContentControl Header="Content:" Style="{StaticResource Style.HeaderedContentControl}">
                <TextBox
                    Height="60"
                    AcceptsReturn="True"
                    Text="{Binding Text.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto" />
            </HeaderedContentControl>

            <HeaderedContentControl Header="Font Family:" Style="{StaticResource Style.HeaderedContentControl}">
                <ComboBox
                    IsEditable="True"
                    ItemsSource="{x:Static Fonts.SystemFontFamilies}"
                    SelectedItem="{Binding FontFamily.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </HeaderedContentControl>

            <local:LabeledTextBox Label="Font Size:">
                <local:LabeledTextBox.Text>
                    <Binding
                        Mode="TwoWay"
                        Path="FontSize.Value"
                        UpdateSourceTrigger="PropertyChanged">
                        <Binding.ValidationRules>
                            <local:DoubleInputValidation InvalidResultString="String.FontSize.Error" MinValue="1" />
                        </Binding.ValidationRules>
                    </Binding>
                </local:LabeledTextBox.Text>
            </local:LabeledTextBox>

            <HeaderedContentControl Header="Font Style:" Style="{StaticResource Style.HeaderedContentControl}">
                <StackPanel Orientation="Horizontal">
                    <CheckBox Content="Bold" IsChecked="{Binding IsBold.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <CheckBox Content="Italic" IsChecked="{Binding IsItalic.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <CheckBox Content="Underline" IsChecked="{Binding IsUnderline.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <CheckBox Content="Strikethrough" IsChecked="{Binding IsStrikethrough.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </HeaderedContentControl>

            <HeaderedContentControl Header="Horizontal Alignment:" Style="{StaticResource Style.HeaderedContentControl}">
                <ComboBox SelectedItem="{Binding HorizontalAlignment.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <vm:TextHorizontalAlignment>Left</vm:TextHorizontalAlignment>
                    <vm:TextHorizontalAlignment>Center</vm:TextHorizontalAlignment>
                    <vm:TextHorizontalAlignment>Right</vm:TextHorizontalAlignment>
                    <vm:TextHorizontalAlignment>Justify</vm:TextHorizontalAlignment>
                </ComboBox>
            </HeaderedContentControl>

            <HeaderedContentControl Header="Vertical Alignment:" Style="{StaticResource Style.HeaderedContentControl}">
                <ComboBox SelectedItem="{Binding VerticalAlignment.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <vm:TextVerticalAlignment>Top</vm:TextVerticalAlignment>
                    <vm:TextVerticalAlignment>Center</vm:TextVerticalAlignment>
                    <vm:TextVerticalAlignment>Bottom</vm:TextVerticalAlignment>
                </ComboBox>
            </HeaderedContentControl>

            <HeaderedContentControl Header="Layout:" Style="{StaticResource Style.HeaderedContentControl}">
                <CheckBox Content="Text Wrap" IsChecked="{Binding IsTextWrapped.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </HeaderedContentControl>

            <local:LabeledTextBox Label="Line Height:">
                <local:LabeledTextBox.Text>
                    <Binding
                        Mode="TwoWay"
                        Path="LineHeight.Value"
                        UpdateSourceTrigger="PropertyChanged">
                        <Binding.ValidationRules>
                            <local:DoubleInputValidation InvalidResultString="String.LineHeight.Error" MinValue="0" />
                        </Binding.ValidationRules>
                    </Binding>
                </local:LabeledTextBox.Text>
            </local:LabeledTextBox>

            <local:LabeledTextBox Label="Letter Spacing:">
                <local:LabeledTextBox.Text>
                    <Binding
                        Mode="TwoWay"
                        Path="LetterSpacing.Value"
                        UpdateSourceTrigger="PropertyChanged">
                        <Binding.ValidationRules>
                            <local:DoubleInputValidation InvalidResultString="String.LetterSpacing.Error" MinValue="0" />
                        </Binding.ValidationRules>
                    </Binding>
                </local:LabeledTextBox.Text>
            </local:LabeledTextBox>

        </StackPanel>-->
    </DataTemplate>

    <DataTemplate x:Key="Private.DataTemplate.PaperEditorMenuStyles.Map.Settings" DataType="{x:Type vm:MapViewModel}">
        <StackPanel Background="{DynamicResource Brush.ToolBackground}" Orientation="Vertical">
            <StackPanel.Resources>
                <Style TargetType="{x:Type local:LabeledTextBox}">
                    <Setter Property="Margin" Value="4" />
                </Style>
                <Style TargetType="{x:Type TextBox}">
                    <Setter Property="Margin" Value="4" />
                </Style>
            </StackPanel.Resources>

            <local:LabeledTextBox Label="Latitude:">
                <local:LabeledTextBox.Text>
                    <Binding
                        Mode="TwoWay"
                        Path="Latitude.Value"
                        UpdateSourceTrigger="PropertyChanged">
                        <Binding.ValidationRules>
                            <local:DoubleInputValidation
                                InvalidResultString="String.Latitude.Error"
                                MaxValue="90"
                                MinValue="-90" />
                        </Binding.ValidationRules>
                    </Binding>
                </local:LabeledTextBox.Text>
            </local:LabeledTextBox>

            <local:LabeledTextBox Label="Longitude:">
                <local:LabeledTextBox.Text>
                    <Binding
                        Mode="TwoWay"
                        Path="Longitude.Value"
                        UpdateSourceTrigger="PropertyChanged">
                        <Binding.ValidationRules>
                            <local:DoubleInputValidation
                                InvalidResultString="String.Longitude.Error"
                                MaxValue="180"
                                MinValue="-180" />
                        </Binding.ValidationRules>
                    </Binding>
                </local:LabeledTextBox.Text>
            </local:LabeledTextBox>

            <HeaderedContentControl Header="Date:" Style="{StaticResource Style.HeaderedContentControl}">
                <DatePicker SelectedDate="{Binding DateTime.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </HeaderedContentControl>

            <HeaderedContentControl Header="Time:" Style="{StaticResource Style.HeaderedContentControl}">
                <local:TimePicker SelectedTime="{Binding Time.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </HeaderedContentControl>

            <Button Command="{Binding ApplyCommand}" Content="Apply" />

        </StackPanel>
    </DataTemplate>

    <ui:DataTypeTemplateSelector x:Key="Private.DataTemplateSelector.PaperEditorMenu.SpecificSettings">
        <ui:PlatformDataTemplateSelectorItem DataTemplate="{StaticResource Private.DataTemplate.PaperEditorMenuStyles.TextItem.Settings}" />
        <ui:PlatformDataTemplateSelectorItem DataTemplate="{StaticResource Private.DataTemplate.PaperEditorMenuStyles.Map.Settings}" />
    </ui:DataTypeTemplateSelector>

    <Style x:Key="Style.ContentControl.PaperEditorMenu.SpecificSettings" TargetType="{x:Type ContentControl}">
        <Setter Property="ContentTemplateSelector" Value="{StaticResource Private.DataTemplateSelector.PaperEditorMenu.SpecificSettings}" />
    </Style>

</ResourceDictionary>