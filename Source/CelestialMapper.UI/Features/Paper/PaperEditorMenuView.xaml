<local:FeatureViewBase
    x:Class="CelestialMapper.UI.PaperEditorMenuView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:CelestialMapper.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:CelestialMapper.ViewModel;assembly=CelestialMapper.ViewModel"
    d:DataContext="{d:DesignInstance Type=vm:PaperEditorMenuViewModel,
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.Style>
            <Style TargetType="Grid">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SelectedPaperItem}" Value="{x:Null}">
                        <Setter Property="IsEnabled" Value="False" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <DataGrid
            ItemsSource="{Binding SelectedPaperItem.Properties}"
            Style="{StaticResource Style.DataGrid.PropertyList}"
            Visibility="{Binding SelectedPaperItem, Converter={x:Static local:Converters.NullMakesMeCollapsed}}">
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="0.4*" Header="Property">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type vm:IPropertyWrapper}">
                            <TextBlock
                                Style="{StaticResource Style.TextBlock.Small}"
                                Text="{Binding Name}"
                                TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn
                    Width="0.6*"
                    CellTemplateSelector="{StaticResource TemplateSelector.PropertyWrapper}"
                    Header="Value" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</local:FeatureViewBase>
